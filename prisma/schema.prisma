// AmbuBook - Schéma Prisma
// Documentation: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL configurée dans prisma.config.ts
}

// ============================================
// BETTER AUTH - Tables d'authentification
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String
  image         String?
  phone         String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true) // Actif par défaut (sauf ambulanciers qui doivent être validés)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations Better Auth
  sessions Session[]
  accounts Account[]

  // Relations métier (ambulanciers)
  company        Company?  @relation("CompanyEmployees", fields: [companyId], references: [id])
  companyId      String?
  ownedCompanies Company[] @relation("CompanyOwner") // Entreprises dont l'user est gérant

  // Relations métier (customers)
  addresses         UserAddress[]
  transportRequests TransportRequest[] @relation("CustomerRequests")

  // Historique et pièces jointes
  historyActions RequestHistory[]    @relation("UserHistoryActions")
  attachments    RequestAttachment[] @relation("UserAttachments")

  // Logs de notifications
  notificationLogs NotificationLog[]

  // Notifications in-app
  inAppNotifications InAppNotification[]

  // Préférences de notifications
  notificationPreferences NotificationPreferences?

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ============================================
// MÉTIER - Tables applicatives
// ============================================

enum UserRole {
  ADMIN
  AMBULANCIER
  CUSTOMER
}

enum TransportType {
  AMBULANCE
  VSL
}

enum MobilityType {
  WALKING    // Patient valide, peut marcher
  WHEELCHAIR // Fauteuil roulant
  STRETCHER  // Brancard
}

enum TripType {
  ONE_WAY    // Aller simple
  ROUND_TRIP // Aller-retour
}

enum RequestStatus {
  PENDING          // En attente de traitement
  ACCEPTED         // Acceptée par l'ambulancier
  REFUSED          // Refusée
  COUNTER_PROPOSAL // Contre-proposition de créneau
  CANCELLED        // Annulée par le patient
  COMPLETED        // Transport effectué
}

enum HistoryEventType {
  CREATED           // Demande créée
  STATUS_CHANGED    // Changement de statut
  COUNTER_PROPOSAL  // Contre-proposition envoyée
  CUSTOMER_RESPONSE // Réponse du client à une contre-proposition
  NOTE_ADDED        // Note ajoutée
  ATTACHMENT_ADDED  // Pièce jointe ajoutée
}

enum AttachmentType {
  TRANSPORT_VOUCHER // Bon de transport
  INVOICE           // Facture
  PRESCRIPTION      // Ordonnance/prescription
  ID_DOCUMENT       // Pièce d'identité
  MUTUELLE          // Carte mutuelle
  SOCIAL_SECURITY   // Carte vitale / attestation sécu
  OTHER             // Autre
}

enum AddressType {
  HOME    // Domicile
  WORK    // Travail
  MEDICAL // Centre médical
  OTHER   // Autre
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // URL publique: /ambulances-dupont
  address     String?
  city        String?
  postalCode  String?
  phone       String?
  email       String?
  siret       String?  @unique
  latitude    Float?   // Coordonnées GPS pour la recherche géolocalisée
  longitude   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Enrichissement page entreprise
  description          String?   @db.Text
  logoUrl              String?
  coverImageUrl        String?
  hasAmbulance         Boolean   @default(true)
  hasVSL               Boolean   @default(true)
  acceptsOnlineBooking Boolean   @default(true)
  foundedYear          Int?
  fleetSize            Int?
  coverageRadius       Int?      // Rayon de couverture en km
  licenseNumber        String?   // N° agrément ARS

  // Gérant de l'entreprise
  owner   User?   @relation("CompanyOwner", fields: [ownerId], references: [id])
  ownerId String?

  // Relations
  users             User[] @relation("CompanyEmployees")
  transportRequests TransportRequest[]
  invitations       Invitation[]
  photos            CompanyPhoto[]
  hours             CompanyHours[]

  @@map("companies")
}

model Invitation {
  id        String    @id @default(cuid())
  code      String    @unique // Code court ex: "ABC123"
  expiresAt DateTime  // Date d'expiration
  usedAt    DateTime? // Date d'utilisation (null si pas utilisé)
  createdAt DateTime  @default(now())

  // Company à rejoindre
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  // Utilisateur qui a créé l'invitation
  createdById String

  // Utilisateur qui a utilisé l'invitation (null si pas encore utilisé)
  usedById String?

  @@index([code])
  @@index([companyId])
  @@map("invitations")
}

// ============================================
// ADRESSES UTILISATEURS
// ============================================

model UserAddress {
  id         String      @id @default(cuid())
  label      String      // "Domicile", "Travail", etc.
  type       AddressType @default(HOME)

  address    String
  city       String
  postalCode String
  details    String?     // Étage, code, digicode, etc.

  isDefault  Boolean     @default(false)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String

  @@index([userId])
  @@map("user_addresses")
}

// ============================================
// DEMANDES DE TRANSPORT
// ============================================

model TransportRequest {
  id          String        @id @default(cuid())
  trackingId  String        @unique @default(cuid()) // Pour le suivi public
  status      RequestStatus @default(PENDING)

  // Informations patient (toujours renseignées, même sans compte)
  patientFirstName String
  patientLastName  String
  patientPhone     String
  patientEmail     String?
  patientBirthDate DateTime? // Date de naissance
  patientSocialSecurityNumber String? // N° sécu pour bon de transport

  // Transport demandé
  transportType       TransportType
  tripType            TripType      @default(ONE_WAY)
  requestedDate       DateTime
  requestedTime       String        // Format HH:mm
  returnDate          DateTime?     // Date de retour (si aller-retour)
  returnTime          String?       // Heure de retour (si aller-retour)
  hasTransportVoucher Boolean       @default(false) // Bon de transport
  isRecurring         Boolean       @default(false) // Transport régulier

  // Mobilité et accompagnement
  mobilityType     MobilityType @default(WALKING)
  needsAccompanist Boolean      @default(false) // Besoin d'un accompagnant
  accompanistName  String?      // Nom de l'accompagnant si besoin

  // Adresses
  pickupAddress    String
  pickupCity       String
  pickupPostalCode String
  pickupDetails    String? // Étage, code, digicode, etc.

  destinationAddress    String
  destinationCity       String
  destinationPostalCode String
  destinationDetails    String? // Service, bâtiment, etc.

  // Motif et notes
  reason String? // Motif du transport (consultation, hospitalisation, dialyse...)
  notes  String? // Notes supplémentaires

  // Contre-proposition (si applicable)
  proposedDate DateTime?
  proposedTime String?

  // Réponse de l'ambulancier
  responseNote String?
  respondedAt  DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  // Relation optionnelle avec un compte utilisateur (customer)
  user   User?   @relation("CustomerRequests", fields: [userId], references: [id])
  userId String?

  // Historique et pièces jointes
  history     RequestHistory[]
  attachments RequestAttachment[]

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([trackingId])
  @@index([requestedDate])
  @@map("transport_requests")
}

// ============================================
// HISTORIQUE DES DEMANDES
// ============================================

model RequestHistory {
  id String @id @default(cuid())

  // Type d'événement
  eventType HistoryEventType

  // Ancien/nouveau statut (pour les changements de statut)
  previousStatus RequestStatus?
  newStatus      RequestStatus?

  // Contre-proposition (si applicable)
  proposedDate DateTime?
  proposedTime String?

  // Métadonnées
  comment   String? // Note explicative
  createdAt DateTime @default(now())

  // Relation avec la demande
  request   TransportRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId String

  // Qui a fait l'action (null si système ou utilisateur non connecté)
  user   User?   @relation("UserHistoryActions", fields: [userId], references: [id])
  userId String?

  @@index([requestId])
  @@index([userId])
  @@index([createdAt])
  @@map("request_history")
}

// ============================================
// PIÈCES JOINTES
// ============================================

model RequestAttachment {
  id String @id @default(cuid())

  // Informations du fichier
  fileName   String         // Nom original du fichier
  fileType   AttachmentType // Type de document
  fileUrl    String         // URL du fichier (stockage externe)
  fileKey    String?        // Clé du fichier dans le stockage (pour suppression)
  fileSizeKb Int            // Taille en KB
  mimeType   String         // application/pdf, image/jpeg, etc.

  createdAt DateTime @default(now())

  // Relation avec la demande
  request   TransportRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId String

  // Qui a uploadé le fichier
  uploadedBy   User   @relation("UserAttachments", fields: [uploadedById], references: [id])
  uploadedById String

  @@index([requestId])
  @@index([uploadedById])
  @@map("request_attachments")
}

// ============================================
// PHOTOS D'ENTREPRISE
// ============================================

model CompanyPhoto {
  id        String   @id @default(cuid())
  fileKey   String   // Clé S3 du fichier
  url       String   // URL signée ou publique
  caption   String?  // Légende optionnelle
  order     Int      @default(0) // Ordre d'affichage
  createdAt DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  @@index([companyId])
  @@map("company_photos")
}

// ============================================
// HORAIRES D'OUVERTURE
// ============================================

model CompanyHours {
  id        String  @id @default(cuid())
  dayOfWeek Int     // 0=Dimanche, 1=Lundi ... 6=Samedi
  openTime  String? // Format HH:mm
  closeTime String? // Format HH:mm
  isClosed  Boolean @default(false)

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  @@unique([companyId, dayOfWeek])
  @@map("company_hours")
}

// ============================================
// LOGS DE NOTIFICATIONS
// ============================================

enum NotificationChannel {
  EMAIL
  SMS
  INAPP
}

enum InAppStatus {
  UNREAD
  READ
  ARCHIVED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

model NotificationLog {
  id        String              @id @default(cuid())
  channel   NotificationChannel // EMAIL ou SMS
  type      String              // Type de notification (TRANSPORT_ACCEPTED, etc.)
  recipient String              // Email ou téléphone
  subject   String?             // Sujet (pour emails)
  content   String?             @db.Text // Contenu du message
  status    NotificationStatus  @default(PENDING)
  errorMsg  String?             // Message d'erreur si échec
  metadata  Json?               // Données additionnelles (transportId, etc.)
  sentAt    DateTime            @default(now())

  // Relation optionnelle avec l'utilisateur
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?

  @@index([userId])
  @@index([channel])
  @@index([type])
  @@index([status])
  @@index([sentAt])
  @@map("notification_logs")
}

// ============================================
// NOTIFICATIONS IN-APP
// ============================================

model InAppNotification {
  id        String      @id @default(cuid())
  type      String      // NotificationType
  title     String
  message   String
  link      String?     // URL de redirection
  status    InAppStatus @default(UNREAD)
  metadata  Json?
  createdAt DateTime    @default(now())
  readAt    DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("in_app_notifications")
}

// ============================================
// PRÉFÉRENCES DE NOTIFICATIONS
// ============================================

model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Canaux activés
  emailEnabled Boolean @default(true)
  smsEnabled   Boolean @default(true)
  inappEnabled Boolean @default(true)

  // Types de notifications
  transportUpdates   Boolean @default(true) // Mises à jour des transports (accepté, refusé, etc.)
  transportReminders Boolean @default(true) // Rappels J-1
  marketing          Boolean @default(false) // Emails marketing / newsletter

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_preferences")
}
