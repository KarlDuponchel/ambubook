// AmbuBook - Schéma Prisma
// Documentation: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL configurée dans prisma.config.ts
}

// ============================================
// BETTER AUTH - Tables d'authentification
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String
  image         String?
  phone         String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true) // Actif par défaut (sauf ambulanciers qui doivent être validés)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations Better Auth
  sessions Session[]
  accounts Account[]

  // Relations métier (ambulanciers)
  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  // Relations métier (customers)
  addresses         UserAddress[]
  transportRequests TransportRequest[] @relation("CustomerRequests")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ============================================
// MÉTIER - Tables applicatives
// ============================================

enum UserRole {
  ADMIN
  AMBULANCIER
  CUSTOMER
}

enum TransportType {
  AMBULANCE
  VSL
}

enum MobilityType {
  WALKING    // Patient valide, peut marcher
  WHEELCHAIR // Fauteuil roulant
  STRETCHER  // Brancard
}

enum TripType {
  ONE_WAY    // Aller simple
  ROUND_TRIP // Aller-retour
}

enum RequestStatus {
  PENDING          // En attente de traitement
  ACCEPTED         // Acceptée par l'ambulancier
  REFUSED          // Refusée
  COUNTER_PROPOSAL // Contre-proposition de créneau
  CANCELLED        // Annulée par le patient
  COMPLETED        // Transport effectué
}

enum AddressType {
  HOME    // Domicile
  WORK    // Travail
  MEDICAL // Centre médical
  OTHER   // Autre
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // URL publique: /ambulances-dupont
  address     String?
  city        String?
  postalCode  String?
  phone       String?
  email       String?
  siret       String?  @unique
  latitude    Float?   // Coordonnées GPS pour la recherche géolocalisée
  longitude   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users             User[]
  transportRequests TransportRequest[]
  invitations       Invitation[]

  @@map("companies")
}

model Invitation {
  id        String    @id @default(cuid())
  code      String    @unique // Code court ex: "ABC123"
  expiresAt DateTime  // Date d'expiration
  usedAt    DateTime? // Date d'utilisation (null si pas utilisé)
  createdAt DateTime  @default(now())

  // Company à rejoindre
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  // Utilisateur qui a créé l'invitation
  createdById String

  // Utilisateur qui a utilisé l'invitation (null si pas encore utilisé)
  usedById String?

  @@index([code])
  @@index([companyId])
  @@map("invitations")
}

// ============================================
// ADRESSES UTILISATEURS
// ============================================

model UserAddress {
  id         String      @id @default(cuid())
  label      String      // "Domicile", "Travail", etc.
  type       AddressType @default(HOME)

  address    String
  city       String
  postalCode String
  details    String?     // Étage, code, digicode, etc.

  isDefault  Boolean     @default(false)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String

  @@index([userId])
  @@map("user_addresses")
}

// ============================================
// DEMANDES DE TRANSPORT
// ============================================

model TransportRequest {
  id          String        @id @default(cuid())
  trackingId  String        @unique @default(cuid()) // Pour le suivi public
  status      RequestStatus @default(PENDING)

  // Informations patient (toujours renseignées, même sans compte)
  patientFirstName String
  patientLastName  String
  patientPhone     String
  patientEmail     String?
  patientBirthDate DateTime? // Date de naissance
  patientSocialSecurityNumber String? // N° sécu pour bon de transport

  // Transport demandé
  transportType       TransportType
  tripType            TripType      @default(ONE_WAY)
  requestedDate       DateTime
  requestedTime       String        // Format HH:mm
  returnDate          DateTime?     // Date de retour (si aller-retour)
  returnTime          String?       // Heure de retour (si aller-retour)
  hasTransportVoucher Boolean       @default(false) // Bon de transport
  isRecurring         Boolean       @default(false) // Transport régulier

  // Mobilité et accompagnement
  mobilityType     MobilityType @default(WALKING)
  needsAccompanist Boolean      @default(false) // Besoin d'un accompagnant
  accompanistName  String?      // Nom de l'accompagnant si besoin

  // Adresses
  pickupAddress    String
  pickupCity       String
  pickupPostalCode String
  pickupDetails    String? // Étage, code, digicode, etc.

  destinationAddress    String
  destinationCity       String
  destinationPostalCode String
  destinationDetails    String? // Service, bâtiment, etc.

  // Motif et notes
  reason String? // Motif du transport (consultation, hospitalisation, dialyse...)
  notes  String? // Notes supplémentaires

  // Contre-proposition (si applicable)
  proposedDate DateTime?
  proposedTime String?

  // Réponse de l'ambulancier
  responseNote String?
  respondedAt  DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  // Relation optionnelle avec un compte utilisateur (customer)
  user   User?   @relation("CustomerRequests", fields: [userId], references: [id])
  userId String?

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([trackingId])
  @@index([requestedDate])
  @@map("transport_requests")
}
